{
  "name": "japanese-corporate-identity",
  "version": "0.1.3",
  "description": "Resolve Japanese corporate identity from messy company names and domains using official NTA and gBizINFO data.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workpodsjun/japanese-corporate-identity.git"
  },
  "homepage": "https://github.com/workpodsjun/japanese-corporate-identity#readme",
  "bugs": {
    "url": "https://github.com/workpodsjun/japanese-corporate-identity/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "japanese-corporate-identity": "dist/bin/jci.js",
    "jci": "dist/bin/jci.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "check:public-boundary": "node scripts/check_public_boundary.mjs",
    "check:pack": "npm pack --dry-run --cache ./.npm-cache",
    "check": "npm run test && npm run check:public-boundary && npm run check:pack"
  },
  "engines": {
    "node": ">=22.6"
  },
  "keywords": [
    "japan",
    "corporate-number",
    "identity-resolution",
    "nta",
    "gbizinfo",
    "data-hygiene"
  ]
}
